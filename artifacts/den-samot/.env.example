# Den Samot shares the Bati Supabase project — copy URL + anon key from bati-attendance/.env.local
# Tables are prefixed ds_ so there's no collision with Bati's tables.
VITE_DS_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_DS_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Same Telegram bot as Bati is fine — just set a different chat ID for the Den Samot group
VITE_DS_TELEGRAM_BOT_TOKEN=same-as-bati-or-new-bot
VITE_DS_TELEGRAM_CHAT_ID=
